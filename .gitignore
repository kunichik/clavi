# Build directories
build/
cmake-build-*/
out/

# Generated binary pack data (built by tools/build_*.py)
*.bin
# Spell dictionary assets are generated from wordlists — track them for builds
!android/app/src/main/assets/spell/*.bin
!ios/ClaviKeyboard/ClaviKeyboardExtension/Resources/spell/*.bin

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# IDE
.vscode/
.idea/
*.user
*.suo
.vs/
*.xcodeproj/
*.xcworkspace/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Linker files
*.ilk

# Debugger Files
*.pdb

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# debug information files
*.dwo
